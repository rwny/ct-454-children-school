/* General Styles */
body {
  margin: 0;
  padding: 0;
  background: #ffffff;
  /* background: linear-gradient(to bottom, #2980b9 0%, #6dd5fa 50%, #d4d4d4 100%); */
  color: #ffffff;
  font-family: 'Noto Sans', sans-serif;
  overflow: hidden;
  width: 100vw;
  height: 100vh;
}

/* Main container for the 3D scene */
#app {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* Loader */
#loader {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(60, 60, 60, 0.7);
  color: #ffffff;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.85rem;
  padding: 10px 20px;
  border-radius: 5px;
  backdrop-filter: blur(5px);
  z-index: 100;
}

/* Main Sidebar Container */
#main-sidebar {
  position: absolute;
  top: 10px;
  right: 10px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  z-index: 1000;
  min-width: 230px;
}

/* Slider Section: Contains both vertical and horizontal sliders */
#slider-section {
  background: rgba(60, 60, 60, 0.7);
  backdrop-filter: blur(10px);
  padding: 12px;
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* Numpad Section: Contains mode and keymap */
#numpad-section {
  background: rgba(60, 60, 60, 0.7);
  backdrop-filter: blur(10px);
  padding: 12px;
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.7rem;
}

#numpad-section div {
  margin: 2px 0;
  padding: 2px 0;
}

#numpad-section #ui-camera-mode {
  color: #cccccc;
  font-weight: bold;
  margin-bottom: 4px;
}

#numpad-section #camera-help {
  color: #cccccc;
}

/* Numpad Rows */
.numpad-row {
  margin: 2px 0;
  line-height: 1.2;
}

.control-group {
  margin-bottom: 15px;
}

.control-group:last-child {
  margin-bottom: 0;
}

/* Toggle Switch Styles */
.toggle-container {
  margin-bottom: 10px;
}

.toggle-switch {
  position: relative;
  display: inline-flex;
  align-items: center;
  cursor: pointer;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.8rem;
  color: #ffffff;
}

.toggle-switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.toggle-slider {
  position: relative;
  width: 40px;
  height: 20px;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20px;
  margin-right: 10px;
  transition: background-color 0.3s;
}

.toggle-slider:before {
  position: absolute;
  content: "";
  height: 16px;
  width: 16px;
  left: 2px;
  bottom: 2px;
  background-color: #ffffff;
  border-radius: 50%;
  transition: transform 0.3s;
}

.toggle-switch input:checked + .toggle-slider {
  background-color: rgba(255, 255, 255, 0.5);
}

.toggle-switch input:checked + .toggle-slider:before {
  transform: translateX(20px);
}

.toggle-label {
  user-select: none;
}

/* Point Size Slider - Enhanced styling to match main sliders */
#point-size-slider {
  --hue: calc(var(--value, 0) * 3.6); /* Scale 0-100 to 0-360 degrees */
  overflow: hidden;
  width: 100%;
  height: 20px;
  accent-color: hsl(var(--hue) 90% 66%);
  outline: none;
  border-radius: 10px;
  margin: 0;
  background: transparent;
}

#point-size-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 40px;
  height: 40px;
  background: hsl(120, 70%, 50%);
  cursor: -webkit-grab;
  border-radius: 50%;
  box-shadow: 0 0 12px rgba(255, 255, 255, 0.7) inset, 0 5px 15px -5px black;
  border: 2px solid hsl(0 0% 50%);
  transition: transform 0.2s, box-shadow 0.2s;
}

#point-size-slider::-webkit-slider-thumb:active {
  cursor: -webkit-grabbing;
  transform: scale(1.1);
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.9) inset, 0 8px 20px -5px black;
}

#point-size-slider::-moz-range-thumb {
  width: 40px;
  height: 40px;
  background: hsl(120, 70%, 50%);
  cursor: pointer;
  border-radius: 50%;
  border: 2px solid hsl(0 0% 50%);
  box-shadow: 0 0 12px rgba(255, 255, 255, 0.7) inset, 0 5px 15px -5px black;
  transition: transform 0.2s, box-shadow 0.2s;
}

#point-size-slider::-moz-range-thumb:active {
  transform: scale(1.1);
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.9) inset, 0 8px 20px -5px black;
}

/* Point Size Slider Container */
#point-size-control .slider-container {
  position: relative;
  padding: 10px 0;
}

/* Point Size Value Display */
#point-size-control .slider-value {
  color: #ffffff;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.8rem;
  text-align: center;
  margin-top: 8px;
  font-weight: 500;
}

/* Custom Properties and Animations for Enhanced Sliders */
@property --value {
  initial-value: 0;
  syntax: '<integer>';
  inherits: true;
}

:root {
  timeline-scope: --thumb-y;
}

/* Animation for value synchronization */
@keyframes sync-y {
  to { --value: 100; }
}

#y-clipping-slider {
  animation: sync-y both linear reverse;
  animation-timeline: --thumb-y;
  animation-range: contain;
}

/* X-Axis Sliders Container */
.x-sliders-container {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-top: 5px;
  width: 100%;
}

.x-slider-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  width: 100%;
}

.x-slider-group .slider-label {
  color: #ffffff;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.75rem;
  text-align: center;
}

.x-slider-group input[type="range"] {
  width: 100%;
  height: 6px;
  background: linear-gradient(to right, #ffffff 0%, #ffffff 50%, #cccccc 50%, #cccccc 100%);
  outline: none;
  border-radius: 3px;
}

/* Radio Button Styles */
.radio-group {
  display: flex;
  flex-direction: row;
  gap: 10px;
  margin-bottom: 5px;
  justify-content: center;
}

.radio-option {
  display: flex;
  align-items: center;
  cursor: pointer;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.75rem;
  color: #ffffff;
  padding: 2px 8px;
  border-radius: 4px;
}

.radio-option input {
  opacity: 0;
  width: 0;
  height: 0;
  position: absolute;
}

.radio-checkmark {
  position: relative;
  width: 16px;
  height: 16px;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  margin-right: 8px;
  transition: background-color 0.3s;
}

.radio-checkmark:after {
  content: "";
  position: absolute;
  display: none;
  top: 4px;
  left: 4px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ffffff;
}

.radio-option input:checked ~ .radio-checkmark {
  background-color: rgba(255, 255, 255, 0.5);
}

.radio-option input:checked ~ .radio-checkmark:after {
  display: block;
}

.radio-label {
  user-select: none;
}

/* Main container for the 3D scene */
#app {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* Main Sidebar Container */
#main-sidebar {
  position: absolute;
  top: 10px;
  right: 10px;
  display: flex;
  flex-direction: column;
  gap: 15px;
  z-index: 100;
  background: transparent;
  padding: 10px;
}

/* Slider Section */
#slider-section {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

/* Control Group */
.control-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 8px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 5px;
  background: rgba(0, 0, 0, 0.3);
}

/* Control Header */
.control-header {
  color: #ffffff;
  font-size: 0.9rem;
  font-weight: 500;
  margin-bottom: 12px;
  text-align: center;
  letter-spacing: 0.05em;
}

/* Slider Container */
.slider-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  position: relative;
}

/* Vertical Slider Container - Full height left sidebar */
#y-slider-container {
  position: fixed;
  left: 0;
  top: 0;
  width: 60px;
  height: 100vh;
  background: rgba(0, 0, 0, 0.0);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px 0;
  box-sizing: border-box;
}

/* Custom Properties for Slider Values */
@property --value {
  initial-value: 0;
  syntax: '<integer>';
  inherits: true;
}

/* Vertical Slider - Full screen height with enhanced styling */
#y-clipping-slider {
  --hue: calc(var(--value, 0));
  overflow: hidden;
  width: 20px;
  height: 80vh;
  accent-color: hsl(var(--hue) 90% 66%);
  outline: none;
  border-radius: 10px;
  -webkit-appearance: slider-vertical;
  appearance: slider-vertical;
  writing-mode: bt-lr;
  margin: 0;
  background: transparent;
}

#y-clipping-slider::-webkit-slider-thumb {
  anchor-name: --thumb-y;
  view-timeline-name: --thumb-y;
  view-timeline-axis: block;
  -webkit-appearance: none;
  appearance: none;
  width: 40px;
  height: 40px;
  background: hsl(120, 70%, 50%);
  cursor: -webkit-grab;
  border-radius: 50%;
  box-shadow: 0 0 12px rgba(255, 255, 255, 0.7) inset, 0 5px 15px -5px black;
  border: 2px solid hsl(0 0% 50%);
  transition: transform 0.2s, box-shadow 0.2s;
}

#y-clipping-slider::-webkit-slider-thumb:active {
  cursor: -webkit-grabbing;
  transform: scale(1.1);
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.9) inset, 0 8px 20px -5px black;
}

#y-clipping-slider::-moz-range-thumb {
  width: 40px;
  height: 40px;
  background: hsl(120, 70%, 50%);
  cursor: pointer;
  border-radius: 50%;
  border: 2px solid hsl(0 0% 50%);
  box-shadow: 0 0 12px rgba(255, 255, 255, 0.7) inset, 0 5px 15px -5px black;
  transition: transform 0.2s, box-shadow 0.2s;
}

#y-clipping-slider::-moz-range-thumb:active {
  transform: scale(1.1);
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.9) inset, 0 8px 20px -5px black;
}

/* Section Bar Container - Bottom of page */
#section-bar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 80px;
  background: rgba(0, 0, 0, 0.0);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 10px;
  box-sizing: border-box;
}

/* Radio Buttons Container */
.radio-group-container {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-right: 30px;
}

/* X-axis Slider Container */
#x-slider-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  max-width: 600px;
}

/* X-axis Slider - Full width with enhanced styling */
#x-clip-slider {
  --hue: calc(var(--value, 0));
  overflow: hidden;
  width: 100%;
  height: 20px;
  accent-color: hsl(var(--hue) 90% 66%);
  outline: none;
  border-radius: 10px;
  margin: 0;
  background: transparent;
}

#x-clip-slider::-webkit-slider-thumb {
  anchor-name: --thumb-x;
  view-timeline-name: --thumb-x;
  view-timeline-axis: inline;
  -webkit-appearance: none;
  appearance: none;
  width: 40px;
  height: 40px;
  background: hsl(120, 70%, 50%);
  cursor: -webkit-grab;
  border-radius: 50%;
  box-shadow: 0 0 12px rgba(255, 255, 255, 0.7) inset, 0 5px 15px -5px black;
  border: 2px solid hsl(0 0% 50%);
  transition: transform 0.2s, box-shadow 0.2s;
}

#x-clip-slider::-webkit-slider-thumb:active {
  cursor: -webkit-grabbing;
  transform: scale(1.1);
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.9) inset, 0 8px 20px -5px black;
}

#x-clip-slider::-moz-range-thumb {
  width: 40px;
  height: 40px;
  background: hsl(120, 70%, 50%);
  cursor: pointer;
  border-radius: 50%;
  border: 2px solid hsl(0 0% 50%);
  box-shadow: 0 0 12px rgba(255, 255, 255, 0.7) inset, 0 5px 15px -5px black;
  transition: transform 0.2s, box-shadow 0.2s;
}

#x-clip-slider::-moz-range-thumb:active {
  transform: scale(1.1);
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.9) inset, 0 8px 20px -5px black;
}

/* Enhanced Slider Value Containers with Value Display */
.slider-value-container {
  position: relative;
  height: 40px;
  width: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Value Display for Y-slider */
#y-slider-container .hint {
  border-radius: 6px;
  color: hsl(0 0% 98%);
  counter-reset: val var(--value);
  display: grid;
  font-size: 0.875rem;
  place-items: center;
  position: absolute;
  right: 100%;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  background: hsl(0 0% 0%);
  border: 1px solid hsl(0 0% 50%);
  box-shadow: 0 1px hsl(0 0% 100% / 0.75) inset, 0 5px 10px -5px black;
  padding: 4px 8px;
  opacity: 0;
  transition: opacity 0.2s;
}

#y-slider-container:hover .hint {
  opacity: 1;
}

#y-slider-container .hint::after {
  content: "Y: " counter(val);
  font-variant: tabular-nums;
  font-weight: 400;
}

/* Special handling for Y-slider container */
.slider-container {
  position: relative;
}

/* Special handling for Y-slider value container */
.slider-container .slider-value-container {
  position: absolute;
  left: -35px;  /* Position to the left of the slider */
  top: 50%;    /* Center vertically */
  transform: translateY(-50%);  /* Perfect vertical centering */
  height: auto;
  width: auto;
  display: flex;
  align-items: center;
  justify-content: flex-end;  /* Right-align the text */
  z-index: 10;
}

/* General slider value styles */
.slider-value {
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.85rem;
  color: #ffffff;
  white-space: nowrap;
  pointer-events: none;
}

/* Specific Y-slider value positioning - already handled by container */
.slider-container .slider-value {
  text-align: right;
}

/* Special positioning for X-slider value */
.x-slider-group .slider-value {
  position: static;
  transform: none;
  left: auto;
  bottom: auto;
  margin-top: 8px;
  font-size: 0.75rem;
}

/* Special positioning for X-slider value container */
.x-slider-group .slider-value-container {
  position: static;
  height: auto;
  width: auto;
}

/* Ensure X-slider value container doesn't conflict with Y-slider */
#container-a .x-slider-group .slider-value-container {
  position: static !important;
  height: auto !important;
  width: auto !important;
}

#container-a .x-slider-group .slider-value {
  position: static !important;
  transform: none !important;
  left: auto !important;
  bottom: auto !important;
  margin-top: 8px !important;
  font-size: 0.75rem !important;
}

/* X-Axis Sliders Container */
.x-sliders-container {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-top: 5px;
  width: 100%;
}

.x-slider-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  width: 100%;
}

.x-slider-group .slider-label {
  color: #ffffff;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.75rem;
  text-align: center;
}

/* Radio Button Styles */
.radio-group {
  display: flex;
  flex-direction: row;
  gap: 10px;
  margin-bottom: 5px;
  justify-content: center;
}

.radio-option {
  display: flex;
  align-items: center;
  cursor: pointer;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.75rem;
  color: #ffffff;
  padding: 2px 8px;
  border-radius: 4px;
}

.radio-option input {
  opacity: 0;
  width: 0;
  height: 0;
  position: absolute;
}

.radio-checkmark {
  position: relative;
  width: 16px;
  height: 16px;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  margin-right: 8px;
  transition: background-color 0.3s;
}

.radio-checkmark:after {
  content: "";
  position: absolute;
  display: none;
  top: 4px;
  left: 4px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ffffff;
}

.radio-option input:checked ~ .radio-checkmark {
  background-color: rgba(255, 255, 255, 0.5);
}

.radio-option input:checked ~ .radio-checkmark:after {
  display: block;
}

.radio-label {
  user-select: none;
}

/* Sidebar Info Container */
#sidebar-info {
  position: absolute;
  top: 10px;
  right: 10px;
  display: flex;
  flex-direction: column;
  gap: 10px; /* Reduced gap */
  z-index: 1000;
  min-width: 200px; /* Reduced width */
  width: 200px; /* Fixed width */
  background: rgba(30, 30, 30, 0.8);
  backdrop-filter: blur(10px);
  border-radius: 10px;
  padding: 10px; /* Reduced padding */
  color: white;
  font-family: 'Noto Sans', sans-serif;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  transition: transform 0.3s ease; /* Smooth sliding animation */
}

#sidebar-info.sidebar-hidden {
  transform: translateX(calc(100% + 20px)); /* Slide out to the right */
}

.sidebar-toggle-btn {
  position: absolute;
  top: 10px;
  left: -40px; /* Position outside the sidebar */
  width: 30px;
  height: 30px;
  background: rgba(30, 30, 30, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 5px 0 0 5px; /* Rounded corners on the left only */
  color: white;
  cursor: pointer;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1001;
  backdrop-filter: blur(10px);
  transition: background 0.3s ease;
}

.sidebar-toggle-btn:hover {
  background: rgba(50, 50, 50, 0.9);
}

/* Sidebar Sections */
.sidebar-section {
  background: rgba(60, 60, 60, 0.7);
  backdrop-filter: blur(10px);
  padding: 12px;
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.75rem;
}

.section-header {
  color: #ffffff;
  font-weight: bold;
  border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  margin-bottom: 8px;
  padding-bottom: 4px;
  font-size: 0.8rem;
}

.section-content {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* Model Info Elements */
#file-name {
  color: #ffffff;
  font-weight: 500;
}

#camera-mode-display {
  color: #cccccc;
}

#point-info {
  color: #aaaaaa;
  font-size: 0.7rem;
}

/* UI Info Elements */
#ui-camera-mode {
  color: #ffffff;
  font-weight: 500;
}

#numpad-help {
  color: #cccccc;
  font-size: 0.65rem;
  line-height: 1.3;
}

#version-display {
  color: #aaaaaa;
  font-size: 0.7rem;
  text-align: center;
  margin-top: 4px;
}

/* Data Section Elements */
.data-item {
  color: #cccccc;
  font-size: 0.7rem;
  padding: 2px 0;
  cursor: pointer;
  transition: color 0.2s;
}

.data-item:hover {
  color: #ffffff;
}

/* Layer Buttons */
.layer-btn {
  background: rgba(76, 175, 80, 0.1);
  border: 1px solid rgba(76, 175, 80, 0.5);
  color: #4CAF50;
  padding: 6px 12px;
  border-radius: 4px;
  cursor: pointer;
  font-family: 'Noto Sans', sans-serif;
  font-size: 0.75rem;
  transition: all 0.2s;
  width: 100%;
  margin-bottom: 8px;
  text-align: left;
}

.layer-btn:hover {
  background: rgba(76, 175, 80, 0.3);
  border-color: #4CAF50;
  color: #ffffff;
}

.layer-btn.active {
  background: #4CAF50;
  color: #ffffff;
  box-shadow: 0 0 10px rgba(76, 175, 80, 0.5);
}

/* Camera Panel */
#camera-panel {
  position: absolute;
  top: 10px;
  right: 10px;
  background: transparent;
  color: #ffffff;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.7rem;
  padding: 8px;
  border-radius: 5px;
  z-index: 100;
  text-align: left;
  min-width: 200px;
}

#camera-panel div {
  margin: 2px 0;
  padding: 2px 0;
}

#camera-panel #camera-mode {
  color: #ffffff;
  font-weight: bold;
  border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  margin-bottom: 4px;
}

#point-count {
  color: #cccccc;
  font-size: 0.8rem;
  margin: 4px 0;
  font-family: 'Noto Sans', 'Courier New', monospace;
}

#version-info {
  color: #aaaaaa;
  font-size: 0.7rem;
  margin: 4px 0;
  font-family: 'Noto Sans', 'Courier New', monospace;
  text-align: center;
}

#camera-panel #camera-help {
  color: #cccccc;
}

.numpad-row {
  margin: 2px 0;
  line-height: 1.2;
}

/* Info Panel */
#info-panel {
  position: absolute;
  bottom: 10px;
  left: 10px;
  background: transparent;
  color: #4CAF50;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 0.8rem;
  padding: 0;
  z-index: 100;
  text-align: left;
}

#info-panel #info {
  color: #4CAF50;
}

/* Loader */
#loader {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: white;
  font-family: 'Noto Sans', 'Courier New', monospace;
  font-size: 1rem;
  z-index: 200;
  text-align: center;
}

/* Toggle Switch */
.toggle-switch {
  position: relative;
  display: inline-block;
  width: 40px;
  height: 20px;
}

.toggle-switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.toggle-slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ccc;
  transition: .4s;
  border-radius: 34px;
}

.toggle-slider:before {
  position: absolute;
  content: "";
  height: 16px;
  width: 16px;
  left: 2px;
  bottom: 2px;
  background-color: white;
  transition: .4s;
  border-radius: 50%;
}

input:checked + .toggle-slider {
  background-color: #2196F3;
}

input:checked + .toggle-slider:before {
  transform: translateX(20px);
}

.toggle-label {
  user-select: none;
}

/* Toggle switch for clip mode */
#clip-mode-toggle {
  margin: 0 5px;
}
.vertical-slider { -webkit-appearance: slider-vertical; appearance: slider-vertical; width: 12px; height: 100%; accent-color: #4CAF50; cursor: pointer; margin: 0; } #y-slider-container { display: none !important; }
