<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/vite.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AAD Pointcloud</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/src/style.css">
</head>

<body>

      
  <!-- Sidebar Info - Top Right -->
  <div id="sidebar-info">
    <button id="sidebar-toggle" class="sidebar-toggle-btn">≡</button>
    
    <!-- Model Info Section -->
    <div class="sidebar-section" id="model-info">
      <div class="section-header">Model Info</div>
      <div class="section-content">
        <div id="file-name">pointcloud - AAD.020</div>
        <div id="camera-mode-display">Mode: Perspective</div>
        <div id="point-info">0 points</div>
      </div>
    </div>
    
    <!-- UI Info Section -->
    <div class="sidebar-section" id="ui-info" style="display: none;">
      <div class="section-content" style="padding-top: 10px;">
        <div id="switch-mode-hint" style="text-align: center; margin-bottom: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">
          <div style="font-size: 2.5rem; font-weight: bold; color: #4CAF50; line-height: 1;">C</div>
          <div style="font-size: 0.7rem; color: #aaaaaa; margin-top: 4px;">switch mode</div>
        </div>
        <div id="ui-camera-mode" style="margin-bottom: 8px; font-weight: bold;">Mode: Fly</div>
        <div id="numpad-help">
          <div class="numpad-row">1:Front | 3:Right | 7:Top | 9:Flip</div>
          <div class="numpad-row">WASD or 8426: Rotate View</div>
          <div class="numpad-row">0:Reset All | 5:P/O Toggle</div>
          <div class="numpad-row">+:Zoom In | -:Zoom Out</div>
        </div>
        <div id="walk-help" style="display: none;">
          <div class="numpad-row">WASD : walk</div>
          <div class="numpad-row">+ shift : sprint</div>
          <div class="numpad-row">+ space bar : jump</div>
        </div>
        

      </div>
    </div>
    
    <!-- Data Section -->
    <div class="sidebar-section" id="data-info" style="display: none;">
      <div class="section-header">Data</div>
      <div class="section-content">
        <div class="data-item" id="x1-data">X1: --</div>
        <div class="data-item" id="x2-data">X2: --</div>
      </div>
    </div>
    
    <!-- Layers Section -->
    <div class="sidebar-section" id="layers-info" style="display: none;">
      <div class="section-header">Layers</div>
      <div class="section-content">
        <button id="toggle-cctv" class="layer-btn">CCTV View</button>
        <!-- Power Lines Hidden as requested -->
      </div>
    </div>

    <!-- Clipping Settings Section -->
    <div class="sidebar-section" id="clipping-settings">
      <div class="section-header">Height Clip</div>
      <div class="section-content">
        <div class="toggle-group" style="margin-bottom: 10px; display: flex; gap: 15px; justify-content: center; align-items: center;">
          <span class="radio-label">Section</span>
          <label class="toggle-switch">
            <input type="checkbox" id="clip-mode-toggle" checked>
            <span class="toggle-slider"></span>
          </label>
          <span class="radio-label">Slice</span>
        </div>
        
        <div class="vertical-clipping-controls" style="display: flex; justify-content: space-around; height: 180px; padding: 10px 0; align-items: stretch;">
           <!-- Height Slider Group -->
           <div class="vertical-slider-group" style="display: flex; flex-direction: column; align-items: center; gap: 8px; flex: 1;">
              <div style="font-size: 0.65rem; color: #aaaaaa; text-transform: uppercase; letter-spacing: 0.05em;">Height</div>
              <input type="range" id="y-clipping-slider" min="0" max="15" step="0.1" value="15" class="vertical-slider">
              <div class="slider-value" id="height-display" style="font-size: 0.75rem;">15.0m</div>
           </div>
           
           <!-- Thickness Slider Group -->
           <div id="slice-thickness-container" class="vertical-slider-group" style="display: flex; flex-direction: column; align-items: center; gap: 8px; flex: 1;">
              <div style="font-size: 0.65rem; color: #aaaaaa; text-transform: uppercase; letter-spacing: 0.05em;">Thickness</div>
              <input type="range" id="slice-thickness-slider" min="0.1" max="1.0" step="0.1" value="0.5" class="vertical-slider" disabled>
              <div class="slider-value" id="thickness-display" style="font-size: 0.75rem; color: #888888;">0.5m</div>
           </div>
        </div>
        

      </div>
    </div>
    
    <!-- Point Size Control -->
    <div class="sidebar-section" id="point-size-control">
      <div class="section-header">Point size</div>
      <div class="section-content">
        <div class="slider-container">
          <input type="range" id="point-size-slider" min="0.01" max="0.09" step="0.02" value="0.05">
          <div class="slider-value-container">
            <!-- <div class="slider-value" id="point-size-value">0.01</div> -->
          </div>
        </div>
        

      </div>
    </div>
    
  </div>
  

  <div id="loader">Loading... 0%</div>
  
  <div id="app"></div>
  <script type="module" src="/src/main.js"></script>
</body>

</html>
